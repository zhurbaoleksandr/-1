#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    double A[200], B[200];

    for (int i = 0; i < n; i++) {
        cin >> A[i];
    }

       double sum = 0;
    for (int i = 0; i < n; i++) {
        sum += A[i];
    }

    
    for (int i = 0; i < n; i++) {
        B[i] = (sum - A[i]) / (n - 1);
    }

    for (int i = 0; i < n; i++) {
        cout << B[i] << " ";
    }

    return 0;
}