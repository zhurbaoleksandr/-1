#include <iostream>
using namespace std;

int main() {
    int n, T;
    cin >> n;

    int A[n];
    for (int i = 0; i < n; i++) {
        cin >> A[i];
    }

    cin >> T;

    int posT = -1;

   
    for (int i = 0; i < n; i++) {
        if (A[i] == T) {
            posT = i;
        }
    }

    int maxNeg = -1000000000;
    int index = -1;

    for (int i = posT + 1; i < n; i++) {
        if (A[i] < 0 && A[i] >= maxNeg) {
            maxNeg = A[i];
            index = i;
        }
    }

    if (index != -1)
        cout << index;
    else
        cout << "Немає";

    return 0;
}